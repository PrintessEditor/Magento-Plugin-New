<?xml version="1.0"?>
<csp_whitelist xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Csp/etc/csp_whitelist.xsd">
    <policies>
        <policy id="img-src">
            <values>
                <value id="printess" type="host">*.printess.com</value>
            </values>
        </policy>
        <policy id="font-src">
            <values>
                <value id="printess" type="host">*.printess.com</value>
            </values>
        </policy>
        <policy id="script-src">
            <values>
                <value id="printess" type="host">*.printess.com</value>
            </values>
        </policy>
        <policy id="connect-src">
            <values>
                <value id="printess" type="host">*.printess.com</value>
                <value id="printess-aws" type="host">printess-prod.s3.eu-central-1.amazonaws.com</value>
                <value id="printess-upload" type="host">printess-upload.s3-accelerate.amazonaws.com</value>
            </values>
        </policy>
        <policy id="frame-src">
            <values>
                <value id="printess" type="host">*.printess.com</value>
            </values>
        </policy>
        <policy id="worker-src">
            <values>
                <value id="printess-worker" type="host">*.printess.com</value>
            </values>
        </policy>
    </policies>
</csp_whitelist>
