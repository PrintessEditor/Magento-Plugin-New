<?xml version="1.0"?>
<csp_whitelist xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Csp/etc/csp_whitelist.xsd">
    <policies>
        <policy id="script-src">
            <values>
                <value id="printess-editor-cdn" type="host">https://editor.printess.com</value>
            </values>
        </policy>
        <policy id="connect-src">
            <values>
                <value id="printess-editor-cdn" type="host">https://editor.printess.com</value>
                <value id="printess-api" type="host">https://api.printess.com</value>
            </values>
        </policy>
        <policy id="frame-src">
            <values>
                <value id="printess-editor-frame" type="host">https://editor.printess.com</value>
            </values>
        </policy>
        <policy id="worker-src">
            <values>
                <value id="printess-worker" type="host">https://editor.printess.com</value>
            </values>
        </policy>
        <policy id="img-src">
            <values>
                <value id="printess-mockups" type="host">https://mockups.printess.com</value>
            </values>
        </policy>
    </policies>
</csp_whitelist>
