<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="printess_projects" resource="default" engine="innodb" comment="Printess Customer Projects">
        <column xsi:type="int" name="project_id" unsigned="true" nullable="false" identity="true" comment="Project ID"/>
        <column xsi:type="int" name="customer_id" unsigned="true" nullable="false" comment="Customer ID"/>
        <column xsi:type="int" name="product_id" unsigned="true" nullable="true" comment="Product ID"/>
        <column xsi:type="smallint" name="store_id" unsigned="true" nullable="false" default="0" comment="Store ID"/>
        <column xsi:type="varchar" name="sku" nullable="true" length="64" comment="Product SKU"/>
        <column xsi:type="varchar" name="product_name" nullable="true" length="255" comment="Product Name"/>
        <column xsi:type="varchar" name="name" nullable="false" length="255" comment="Project Name"/>
        <column xsi:type="varchar" name="save_token" nullable="false" length="512" comment="Printess Save Token"/>
        <column xsi:type="text" name="thumbnail_url" nullable="true" comment="Printess Thumbnail URL"/>
        <column xsi:type="timestamp" name="expires_at" nullable="true" on_update="false" comment="Expires At"/>
        <column xsi:type="timestamp" name="order_reminder_sent_at" nullable="true" on_update="false" comment="Order Reminder Sent At"/>
        <column xsi:type="timestamp" name="removal_reminder_sent_at" nullable="true" on_update="false" comment="Removal Reminder Sent At"/>
        <column xsi:type="timestamp" name="ordered_at" nullable="true" on_update="false" comment="Ordered At"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="false" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="false" comment="Last Printess Save At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="project_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="PRINTESS_PROJECT_CUSTOMER_ID_CUSTOMER_ENTITY_ENTITY_ID"
                    table="printess_projects" column="customer_id"
                    referenceTable="customer_entity" referenceColumn="entity_id" onDelete="CASCADE"/>
        <constraint xsi:type="foreign" referenceId="PRINTESS_PROJECT_STORE_ID_STORE_STORE_ID"
                    table="printess_projects" column="store_id"
                    referenceTable="store" referenceColumn="store_id" onDelete="CASCADE"/>
        <index referenceId="PRINTESS_PROJECT_CUSTOMER_ID_UPDATED_AT" indexType="btree">
            <column name="customer_id"/>
            <column name="updated_at"/>
        </index>
        <index referenceId="PRINTESS_PROJECT_EXPIRES_AT" indexType="btree">
            <column name="expires_at"/>
        </index>
        <index referenceId="PRINTESS_PROJECT_SAVE_TOKEN" indexType="btree">
            <column name="save_token"/>
        </index>
    </table>

    <table name="printess_pdf_jobs" resource="default" engine="innodb" comment="Printess Async PDF Production Jobs">
        <column xsi:type="int" name="job_id" unsigned="true" nullable="false" identity="true" comment="Job ID"/>
        <column xsi:type="int" name="order_id" unsigned="true" nullable="false" comment="Sales Order entity_id"/>
        <column xsi:type="int" name="order_item_id" unsigned="true" nullable="false" comment="Sales Order Item item_id"/>
        <column xsi:type="varchar" name="save_token" nullable="false" length="512" comment="Printess Save Token"/>
        <column xsi:type="varchar" name="printess_job_id" nullable="true" length="255" comment="Printess Production Job ID"/>
        <column xsi:type="varchar" name="status" nullable="false" length="32" default="pending" comment="Status: pending|producing|complete|failed"/>
        <column xsi:type="varchar" name="pdf_path" nullable="true" length="512" comment="Saved PDF path relative to var/"/>
        <column xsi:type="smallint" name="fail_count" unsigned="true" nullable="false" default="0" comment="Consecutive failure count"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="false" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="job_id"/>
        </constraint>
        <index referenceId="PRINTESS_PDF_JOBS_STATUS" indexType="btree">
            <column name="status"/>
        </index>
        <index referenceId="PRINTESS_PDF_JOBS_ORDER_ID" indexType="btree">
            <column name="order_id"/>
        </index>
        <index referenceId="PRINTESS_PDF_JOBS_ORDER_ITEM_ID" indexType="btree">
            <column name="order_item_id"/>
        </index>
    </table>
</schema>
