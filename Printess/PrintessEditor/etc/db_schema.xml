<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="printess_saved_projects" resource="default" engine="innodb"
           comment="Printess Saved Projects">
        <column xsi:type="int" name="id" nullable="false" identity="true" unsigned="true"
                comment="Project ID"/>
        <column xsi:type="int" name="customer_id" nullable="false" unsigned="true"
                comment="Customer ID"/>
        <column xsi:type="varchar" name="name" nullable="false" length="255" default=""
                comment="Project Name"/>
        <column xsi:type="text" name="save_token" nullable="false"
                comment="Printess Save Token"/>
        <column xsi:type="timestamp" name="created_at" nullable="false"
                default="CURRENT_TIMESTAMP" on_update="false" comment="Created At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>
        <index referenceId="PRINTESS_SAVED_PROJECTS_CUSTOMER_ID" indexType="btree">
            <column name="customer_id"/>
        </index>
    </table>
</schema>
