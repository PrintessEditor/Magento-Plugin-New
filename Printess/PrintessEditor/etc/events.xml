<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">
    <event name="checkout_cart_product_add_after">
        <observer name="printess_save_token_to_cart" instance="Printess\PrintessEditor\Observer\SaveTokenToCart"/>
    </event>
    <event name="sales_model_service_quote_submit_before">
        <observer name="printess_transfer_to_order" instance="Printess\PrintessEditor\Observer\TransferToOrder"/>
    </event>
    <event name="sales_order_place_after">
        <observer name="printess_produce_pdf" instance="Printess\PrintessEditor\Observer\ProducePdf"/>
        <observer name="printess_mark_saved_project_ordered"
                  instance="Printess\PrintessEditor\Observer\MarkSavedProjectOrdered"/>
    </event>
</config>
